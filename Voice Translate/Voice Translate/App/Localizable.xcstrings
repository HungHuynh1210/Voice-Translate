            "state" : "translated",
            "value" : "Bạn có thể xóa vĩnh viễn bản sao giọng nói của mình bất kỳ lúc nào trong Cài đặt."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您可以隨時在「設定」中永久刪除您的語音複製。"
          }
        }
      }
    },
    "Your cloned voice will automatically expire after 30 days if it isn't used." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihre geklonte Stimme läuft nach 30 Tagen automatisch ab, wenn sie nicht verwendet wird."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Su voz clonada caducará automáticamente después de 30 días si no se utiliza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "クローンされた音声は、使用されない場合、30 日後に自動的に期限切れになります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
