          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " chế độ hoặc chế độ đối thoại không cần chạm cho người nói hai ngôn ngữ khác nhau."
          }
        },
        "zh-Hant" : {
