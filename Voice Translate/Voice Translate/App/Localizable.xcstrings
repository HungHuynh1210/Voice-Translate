        }
      }
    },
    " and reopening it to try again." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "und öffnen Sie es erneut, um es erneut zu versuchen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "y volver a abrirlo para volver a intentarlo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "再度開いて再試行してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "다시 열어서 다시 시도해 보세요."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "e reabrindo-o para tentar novamente."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " và mở lại để thử lại."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "並重新打開它再試一次。"
          }
        }
      }
    },
    " arrow is your mother tongue. (In the latest version, the mother tongue language has the Me logo)" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pfeil ist deine Muttersprache. (In der neuesten Version hat die Muttersprache das Me-Logo)"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La flecha es tu lengua materna. (En la última versión, el idioma materno tiene el logo Yo)"
