    "\"Forget\" the headset in your device's Bluetooth settings, and then go through the pairing process again." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Vergessen“ Sie das Headset in den Bluetooth-Einstellungen Ihres Geräts und führen Sie dann den Kopplungsvorgang erneut durch."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Olvídese\" de los auriculares en la configuración de Bluetooth de su dispositivo y luego realice el proceso de emparejamiento nuevamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "デバイスの Bluetooth 設定でヘッドセットを「削除」し、ペアリング プロセスを再度実行します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "장치의 Bluetooth 설정에서 헤드셋을 \"삭제\"한 다음 페어링 과정을 다시 진행하세요."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Esqueça\" o fone de ouvido nas configurações de Bluetooth do seu dispositivo e repita o processo de emparelhamento."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Quên\" tai nghe trong cài đặt Bluetooth của thiết bị của bạn, rồi thực hiện lại quá trình ghép nối."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在裝置的藍牙設定中「忘記」耳機，然後再次執行配對過程。"
          }
        }
      }
    },
