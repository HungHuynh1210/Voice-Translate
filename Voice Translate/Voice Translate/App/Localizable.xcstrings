    "To protect your privacy, your voice clone will be automatically deleted after 30 days of inactivity." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um Ihre Privatsphäre zu schützen, wird Ihr Sprachklon nach 30 Tagen Inaktivität automatisch gelöscht."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para proteger tu privacidad, tu clon de voz se eliminará automáticamente después de 30 días de inactividad."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プライバシーを保護するため、音声クローンは 30 日間非アクティブな状態が続くと自動的に削除されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "개인정보 보호를 위해 음성 복제는 30일 동안 활동이 없으면 자동으로 삭제됩니다."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para proteger sua privacidade, seu clone de voz será excluído automaticamente após 30 dias de inatividade."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Để bảo vệ quyền riêng tư của bạn, bản sao giọng nói của bạn sẽ tự động bị xóa sau 30 ngày không hoạt động."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "為了保護您的隱私，您的語音複製將在 30 天不活動後自動刪除。"
          }
        }
      }
    },
