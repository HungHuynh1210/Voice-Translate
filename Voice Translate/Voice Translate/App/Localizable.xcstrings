          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Estás seguro de que deseas eliminar tu voz clonada? Necesitará grabar una nueva muestra para crear otro clon de voz."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "クローンした音声を削除してもよろしいですか?別の音声クローンを作成するには、新しいサンプルを録音する必要があります。"
